  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_03074">
    <ns1:hasDbXref>Thesaurus.owl#C191613</ns1:hasDbXref>
    <obo:IAO_0000115>The ratio of fraction of inspired oxygen (FiO2) to positive end-expiratory pressure (PEEP). This measured value may be adjusted on a mechanical ventilator to optimize treatment.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03281">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Parsimonious ARDS subphenotype classifier</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <obo:IAO_0000115 xml:lang="en">Real-time bedside classification model using only 3 readily available variables — IL-8 (plasma), Protein C (plasma), and Bicarbonate (serum) — to distinguish hyperinflammatory from hypoinflammatory ARDS subphenotype. AUROC ~0.90 in validation cohorts. Avoids need for full cytokine panel. Enables rapid treatment personalisation in ICU settings. Sinha 2020 (PMID:32461733); Maslove 2022.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">3-variable ARDS subphenotype model</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">IL-8 Protein-C Bicarbonate classifier</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Bedside ARDS phenotyping tool</obo:hasExactSynonym>
    <obo:hasDbXref>PMID:32461733</obo:hasDbXref>
    <obo:source_pmid>32461733</obo:source_pmid>
    <poi:hasBiomarker rdf:resource="http://poi-kb.org/ards/ARDS_POI_03206"/>
    <poi:hasBiomarker rdf:resource="http://poi-kb.org/ards/ARDS_POI_03282"/>
    <poi:hasBiomarker rdf:resource="http://poi-kb.org/ards/ARDS_POI_03283"/>
    <rdfs:comment xml:lang="en">IL-8: primary inflammatory variable in parsimonious model.</rdfs:comment>
    <rdfs:comment xml:lang="en">Protein C: coagulation/endothelial variable.</rdfs:comment>
    <rdfs:comment xml:lang="en">Bicarbonate: acid-base variable reflecting metabolic acidosis.</rdfs:comment>
    <rdfs:comment xml:lang="en">Parsimonious classifier targets this subphenotype for classification.</rdfs:comment>
    <poi:hasClinicalOutcome rdf:resource="http://poi-kb.org/ards/ARDS_POI_03200"/>
    <poi:hasClinicalOutcome rdf:resource="http://poi-kb.org/ards/ARDS_POI_03201"/>
  </rdf:Description>
