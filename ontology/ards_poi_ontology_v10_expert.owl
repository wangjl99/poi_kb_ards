    <obo:hasDbXref>UMLS:C0035222</obo:hasDbXref>
    <obo:hasDbXref>PMID:22360949</obo:hasDbXref>
    <obo:hasDbXref>biolink:Disease</obo:hasDbXref>
    <owl:equivalentClass rdf:resource="http://snomed.info/id/67782005"/>
    <poi:hasRiskFactor rdf:resource="http://poi-kb.org/ards/ARDS_POI_01360"/>
    <poi:hasSeverityStage rdf:resource="http://poi-kb.org/ards/ARDS_POI_03121"/>
  </rdf:Description>
