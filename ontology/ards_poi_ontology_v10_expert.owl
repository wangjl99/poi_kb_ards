  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03230">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Right ventricular dysfunction ARDS population</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_population"/>
    <obo:IAO_0000115 xml:lang="en">ARDS patients with echocardiographic acute cor pulmonale or RV dysfunction. Relative contraindication to high-PEEP and aggressive recruitment. Incidence 20–30% in moderate-severe ARDS by echocardiography. Mechanism: hypoxic pulmonary vasoconstriction + hypercapnia + PEEP → elevated pulmonary vascular resistance → RV pressure overload → RV dilation. High PEEP and aggressive recruitment can worsen RV afterload — relative contraindications. Prone positioning may paradoxically improve RV function by reducing hypoxic vasoconstriction. Echocardiographic monitoring recommended before escalating PEEP. PMID:20558628 + recent 2024 echo-ARDS studies.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">ARDS with acute cor pulmonale</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D006333</obo:hasDbXref>
    <poi:isContraindicatedIn rdf:resource="http://poi-kb.org/ards/ARDS_POI_03285"/>
    <poi:isContraindicatedIn rdf:resource="http://poi-kb.org/ards/ARDS_POI_03286"/>
    <rdfs:comment xml:lang="en">High PEEP increases RV afterload → may precipitate acute cor pulmonale.</rdfs:comment>
    <rdfs:comment xml:lang="en">Aggressive recruitment maneuvers increase RV afterload via transient high airway pressures — avoid in confirmed RV dysfunction.</rdfs:comment>
    <obo:source_pmid>20558628</obo:source_pmid>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01829">
