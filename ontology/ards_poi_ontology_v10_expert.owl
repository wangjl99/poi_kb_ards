  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03011">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">N 3 fatty acid gamma linolenic acid antioxidant enteral supplementation</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03280">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Mechanical power exceeding 17 J/min</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
    <rdfs:subClassOf rdf:resource="http://poi-kb.org/ards/ARDS_POI_03227"/>
    <obo:IAO_0000115 xml:lang="en">Ventilator-delivered mechanical power (MP) to the respiratory system exceeding 17 J/min — the dose-dependent mortality threshold established in ARDS cohorts (Serpa Neto 2018 PMID:28985207; Coppola 2024). MP = 0.098 × RR × Vt × [Peak pressure − PEEP/2]. Higher MP associated with VILI regardless of subphenotype, but hyperinflammatory and non-focal phenotypes may be more susceptible. Threshold varies by analysis (17–18.7 J/min across studies).</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">MP &gt;17 J/min</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">High mechanical power ARDS</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Elevated MP threshold</obo:hasExactSynonym>
    <obo:hasDbXref>PMID:28985207</obo:hasDbXref>
    <obo:source_pmid>28985207</obo:source_pmid>
    <poi:hasRiskFactor rdf:resource="http://poi-kb.org/ards/ARDS_POI_03226"/>
    <rdfs:comment xml:lang="en">Elevated driving pressure is the dominant contributor to mechanical power. ΔP reduction is the primary lever for MP control.</rdfs:comment>
    <rdfs:comment xml:lang="en">EIT enables regional distribution of mechanical power — identifies overdistension hot-spots not visible from global MP calculation.</rdfs:comment>
    <poi:measuredBy rdf:resource="http://poi-kb.org/ards/ARDS_POI_03216"/>
  </rdf:Description>
