  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01006">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">dexamethasone treatment for hospitalized COVID-19</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <rdfs:subClassOf rdf:resource="http://poi-kb.org/ards/glucocorticoid-drug-therapy"/>
    <obo:hasDbXref>MESH:D059495</obo:hasDbXref>
    <obo:hasDbXref>UMLS:C5203912</obo:hasDbXref>
    <obo:source_pmid>32678530</obo:source_pmid>
    <obo:IAO_0000115 xml:lang="en">Synthetic glucocorticoid. DEXA-ARDS trial (PMID 32043986): 20 mg IV QD days 1–5 then 10 mg QD days 6–10; 60-day mortality 21% vs 36% (P=0.005); +4.8 ventilator-free days. Only pharmacological agent with proven mortality benefit in non-COVID ARDS. Converges with RECOVERY trial to establish dexamethasone as cornerstone pharmacotherapy.</obo:IAO_0000115>
    <owl:equivalentClass rdf:resource="http://snomed.info/id/372584003"/>
    <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/CHEBI_41879"/>
  </rdf:Description>
