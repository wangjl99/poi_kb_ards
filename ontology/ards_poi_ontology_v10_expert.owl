  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01288">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Ziprasidone for delirium in critical illness</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <obo:hasDbXref>MESH:D016481</obo:hasDbXref>
