    <obo:hasExactSynonym xml:lang="en">Plasma bicarbonate</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Bicarbonate serum level</obo:hasExactSynonym>
    <obo:hasDbXref>LOINC:1963-8</obo:hasDbXref>
    <obo:hasDbXref>MESH:D001639</obo:hasDbXref>
    <obo:source_pmid>32461733</obo:source_pmid>
