  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_01832">
    <ns1:hasDbXref>Thesaurus.owl#C206709</ns1:hasDbXref>
    <obo:IAO_0000115>Postmortem harvesting of tumor tissue within hours of death for the purpose of cancer research using techniques that include DNA sequencing, RNA expression analysis, proteomics, and immunohistochemical studies.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03202">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Focal ARDS</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_disease"/>
    <obo:IAO_0000115 xml:lang="en">CT-defined ARDS phenotype with unilateral or lobar consolidation. Recruitable at low pressures; high risk of overdistension with high PEEP. Gattinoni-Marini CT phenotype classification (PMID 30342773). Focal morphology (dorsal-caudal consolidations on CT/EIT/LUS): better response to prone positioning (gravitational redistribution). High PEEP and aggressive recruitment RELATIVELY contraindicated — higher risk of overdistension of aerated regions. Lower recruitability per electrical impedance tomography.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Lobar ARDS</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Focal lung involvement ARDS</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D012128</obo:hasDbXref>
    <obo:source_pmid>30342773</obo:source_pmid>
    <owl:disjointWith rdf:resource="http://poi-kb.org/ards/ARDS_POI_03203"/>
    <rdfs:subClassOf rdf:resource="http://poi-kb.org/ards/ARDS_POI_03270"/>
    <rdfs:comment xml:lang="en">Focal ARDS: lower PEEP preferred (high overdistension risk). High PEEP strategy harmful in this morphology (ART trial mechanistic analysis). Responds to prone positioning.</rdfs:comment>
    <rdfs:comment xml:lang="en">Focal ARDS: stronger prone positioning benefit due to gravitational redistribution of dorsal consolidations. PMID:30342773</rdfs:comment>
    <rdfs:comment xml:lang="en">Focal ARDS: high PEEP relatively contraindicated — overdistension risk in aerated lung regions exceeds atelectasis benefit.</rdfs:comment>
    <rdfs:comment xml:lang="en">Focal ARDS: aggressive recruitment maneuvers relatively contraindicated (ART trial harm signal; focal morphology increases overdistension risk).</rdfs:comment>
    <rdfs:comment xml:lang="en">EIT quantifies regional ventilation distribution — identifies focal consolidation pattern and recruitability in real time.</rdfs:comment>
    <poi:hasDifferentialResponse rdf:resource="http://poi-kb.org/ards/ARDS_POI_01121"/>
    <poi:isContraindicatedIn rdf:resource="http://poi-kb.org/ards/ARDS_POI_03285"/>
    <poi:isContraindicatedIn rdf:resource="http://poi-kb.org/ards/ARDS_POI_03286"/>
    <poi:measuredBy rdf:resource="http://poi-kb.org/ards/ARDS_POI_03216"/>
  </rdf:Description>
