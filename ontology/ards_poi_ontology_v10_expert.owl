  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03205">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Interleukin-6</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_biomarker"/>
    <obo:IAO_0000115 xml:lang="en">Pro-inflammatory cytokine. Plasma IL-6 &gt;400 pg/mL classifies hyperinflammatory ARDS subphenotype. Target of tocilizumab/sarilumab.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">IL-6</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Interleukin 6</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">BSF-2</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">IFNB2</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D015850</obo:hasDbXref>
    <obo:hasDbXref>UMLS:C0085295</obo:hasDbXref>
    <obo:hasDbXref>CHEBI:138181</obo:hasDbXref>
    <obo:source_pmid>25030514</obo:source_pmid>
    <owl:equivalentClass rdf:resource="http://purl.obolibrary.org/obo/CHEBI_138181"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03282">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Protein C</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_biomarker"/>
    <obo:IAO_0000115 xml:lang="en">Anticoagulant serine protease. LOW plasma Protein C is a key feature of hyperinflammatory ARDS subphenotype; HIGHER levels characterise hypoinflammatory phenotype. Part of the parsimonious 3-variable classifier (Sinha 2020 PMID:32461733). Reflects endothelial activation and procoagulant state in ARDS.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">PC</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PROC</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Coagulation factor XIV</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D017148</obo:hasDbXref>
    <obo:hasDbXref>UMLS:C0072020</obo:hasDbXref>
    <obo:hasDbXref>PMID:32461733</obo:hasDbXref>
    <obo:source_pmid>32461733</obo:source_pmid>
  </rdf:Description>
