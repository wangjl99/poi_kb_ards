  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03287">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Extravascular lung water index</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
    <obo:IAO_0000115 xml:lang="en">Extravascular lung water index (EVLWI) and Pulmonary Vascular Permeability Index (PVPI) measured via transpulmonary thermodilution. EVLWI &gt;10 mL/kg and PVPI &gt;3 indicate increased permeability pulmonary oedema (ARDS pattern). Used for phenotype-guided fluid management: high EVLWI in hyperinflammatory subphenotype favours conservative fluids. Low EVLWI with high PVPI suggests early permeability oedema.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">EVLWI</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PVPI</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Extravascular lung water</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PiCCO EVLW</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D062080</obo:hasDbXref>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01390">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
