  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_01130">
    <ns1:hasDbXref>Thesaurus.owl#C71505</ns1:hasDbXref>
    <obo:IAO_0000115>A statistical sampling technique that involves related observations that come from the same individuals or subjects measured under two or more different conditions or at different times, such as blood pressure taken in the morning and then in the afternoon.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03284">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Conservative fluid management strategy</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <obo:IAO_0000115 xml:lang="en">Restrictive fluid strategy targeting zero or negative cumulative fluid balance in ARDS. FACTT trial (PMID:16714767): negative fluid balance improved oxygenation and reduced ventilator days without increasing renal failure. HTE analysis (Calfee 2018): mortality benefit concentrated in hyperinflammatory subphenotype. Liberal fluid may worsen pulmonary oedema, especially in hyperinflammatory patients.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Restrictive fluid strategy ARDS</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Negative fluid balance ARDS</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Fluid conservative ARDS management</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">FACTT conservative arm</obo:hasExactSynonym>
    <obo:hasDbXref>PMID:16714767</obo:hasDbXref>
    <obo:source_pmid>16714767</obo:source_pmid>
  </rdf:Description>
