  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03216">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Ultra-protective ventilation during VV-ECMO</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <obo:IAO_0000115 xml:lang="en">Vt 2–4 ml/kg PBW + RR 10–14/min + Pplat ≤25 cmH₂O during VV-ECMO. Proposed mechanism of EOLIA benefit (PMID 29791822).</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Lung rest strategy</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">ECMO lung rest</obo:hasExactSynonym>
