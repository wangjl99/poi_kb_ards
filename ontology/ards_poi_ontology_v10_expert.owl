  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03286">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Aggressive recruitment maneuver strategy</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
    <obo:IAO_0000115 xml:lang="en">High sustained inflation pressure (&gt;40 cmH₂O) recruitment maneuvers aimed at opening collapsed lung. ART trial (PMID:28973363): HR 1.20 for 28-day mortality — definitive harm in unselected moderate-severe ARDS. Relatively contraindicated in focal ARDS (overdistension), RV dysfunction (afterload), and hypoinflammatory subphenotype. May have a role in non-focal ARDS with high recruitability.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">High-pressure recruitment ARDS</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Aggressive RM</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">ART-style recruitment</obo:hasExactSynonym>
    <obo:hasDbXref>PMID:28973363</obo:hasDbXref>
    <obo:source_pmid>28973363</obo:source_pmid>
  </rdf:Description>
