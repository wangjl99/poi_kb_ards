  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03045">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Peep optimization for ards</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <obo:IAO_0000115 xml:lang="en">Life-threatening syndrome of acute diffuse inflammatory lung injury. 2012 Berlin criteria: acute onset within 1 week of clinical insult; bilateral opacities on imaging; PaO₂/FiO₂ ≤300 mmHg on PEEP ≥5 cmH₂O; not fully explained by cardiac failure or fluid overload. Severity: mild 200&lt;P/F≤300; moderate 100&lt;P/F≤200; severe P/F≤100 mmHg.</obo:IAO_0000115>
    <owl:equivalentClass rdf:resource="http://poi-kb.org/ards/ARDS_POI_02850"/>
  </rdf:Description>
