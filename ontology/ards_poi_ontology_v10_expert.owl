    <obo:IAO_0000115>Any process that modulates the frequency, rate or extent of an inflammasome-mediated signaling pathway.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01121">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">prone positioning</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <rdfs:subClassOf rdf:resource="http://poi-kb.org/ards/ventilation-strategy"/>
    <obo:hasDbXref>MESH:D012128</obo:hasDbXref>
    <obo:hasDbXref>UMLS:C0035222</obo:hasDbXref>
    <obo:source_pmid>19903918</obo:source_pmid>
    <obo:source_pmid>24102072</obo:source_pmid>
    <obo:source_pmid>24435203</obo:source_pmid>
    <obo:source_pmid>33823862</obo:source_pmid>
    <obo:source_pmid>33464919</obo:source_pmid>
    <obo:source_pmid>14668608</obo:source_pmid>
    <obo:source_pmid>11529210</obo:source_pmid>
    <owl:equivalentClass rdf:resource="http://snomed.info/id/431182000"/>
    <obo:IAO_0000115 xml:lang="en">Repositioning of mechanically ventilated patient face-down for ≥16h per session. PROSEVA (PMID 23688302): 28-day mortality 16.0% vs 32.8%, HR 0.39 (0.25–0.63), P&lt;0.001. Indicated for severe ARDS (PaO₂/FiO₂ &lt;150). Mechanisms: reduction of dorsal atelectasis, V/Q redistribution, decreased physiological dead space.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Proning</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Prone position ventilation</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PPV</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Mechanical prone ventilation</obo:hasExactSynonym>
    <poi:hasDifferentialResponse rdf:resource="http://poi-kb.org/ards/ARDS_POI_03202"/>
    <rdfs:comment xml:lang="en">Prone positioning shows stronger benefit in focal ARDS (CT morphology). PMID:30342773</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_02537">
    <ns1:hasDbXref>Thesaurus.owl#C50415</ns1:hasDbXref>
    <obo:IAO_0000115>Evidence of improved patient condition.</obo:IAO_0000115>
  </rdf:Description>
