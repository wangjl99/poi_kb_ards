  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_02222">
    <ns1:hasDbXref>Thesaurus.owl#C167116</ns1:hasDbXref>
    <obo:IAO_0000115>The addition of creatine to an individual's daily diet. It is most commonly used for improving exercise performance and increasing muscle mass in athletes and older adults.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_03083">
    <ns1:hasDbXref>Thesaurus.owl#C125711</ns1:hasDbXref>
    <obo:IAO_0000115>A syndrome caused by Kaposi sarcoma-associated herpesvirus (KSHV) infection. It manifests with fever, weight loss, and fluid retention in the legs or abdomen. Patients are at risk of developing KSHV-related cancers including Kaposi sarcoma and lymphoma.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_03124">
    <ns1:hasDbXref>D014789</ns1:hasDbXref>
