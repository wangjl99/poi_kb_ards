    <obo:source_pmid>17962636</obo:source_pmid>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_02150">
    <ns1:hasDbXref>Thesaurus.owl#C50430</ns1:hasDbXref>
    <obo:IAO_0000115>A condition that requires mechanical life support due to inability to breath effectively to maintain normal levels of oxygen and carbon dioxide in the body.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/hasDifferentialResponse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">has differential response</rdfs:label>
    <obo:IAO_0000115 xml:lang="en">A relation between an intervention and a disease subphenotype or clinical context indicating that the intervention produces a qualitatively different effect (benefit vs harm vs null) in that subphenotype compared to the overall ARDS population. Key examples: prone positioning in focal vs non-focal ARDS; higher PEEP in hyperinflammatory vs hypoinflammatory subphenotypes.</obo:IAO_0000115>
    <obo:hasDbXref>biolink:related_to</obo:hasDbXref>
    <obo:hasDbXref>RO:0002434</obo:hasDbXref>
  </rdf:Description>
