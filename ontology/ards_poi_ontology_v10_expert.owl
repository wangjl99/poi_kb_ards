  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03261">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Severe ARDS context PaO2/FiO2 less than 150</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_context"/>
    <obo:IAO_0000115 xml:lang="en">Clinical context defined by PaO₂/FiO₂ &lt;150 mmHg on PEEP ≥5 cmH₂O for &gt;12–36h on mechanical ventilation. Mandatory eligibility threshold for prone positioning benefit (PROSEVA, PMID 23688302) and a key criterion for VV-ECMO consideration (EOLIA, PMID 29791822).</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">PaO2/FiO2 &lt;150 mmHg ARDS context</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PROSEVA eligibility threshold</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Severe ARDS hypoxaemia context</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Severe ARDS context PaO2/FiO2 &lt;150</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Severe ARDS context PaO₂/FiO₂ &lt;150 mmHg</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">PROSEVA severity threshold PaO2/FiO2 &lt;150</obo:hasExactSynonym>
    <obo:hasDbXref>PMID:23688302</obo:hasDbXref>
    <obo:hasDbXref>PMID:29791822</obo:hasDbXref>
    <obo:source_pmid>23688302</obo:source_pmid>
  </rdf:Description>
