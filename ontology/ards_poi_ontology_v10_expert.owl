  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03224">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Biotrauma</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
    <obo:IAO_0000115 xml:lang="en">Inflammatory VILI mediated by cytokines (IL-1β, IL-6, IL-8, TNF-α) released from mechanically stressed lung into systemic circulation, linking ventilator injury to distal organ failure.</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Ventilator-induced biotrauma</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">VILI-mediated systemic inflammation</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D055371</obo:hasDbXref>
  </rdf:Description>
