  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03222">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Volutrauma</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_mechanism"/>
    <obo:IAO_0000115 xml:lang="en">VILI from excessive tidal volume causing alveolar overdistension. Prevented by 6 ml/kg PBW strategy (ARMA, PMID 10793162).</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">Volume-induced lung injury</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Alveolar overdistension injury</obo:hasExactSynonym>
    <obo:hasDbXref>MESH:D055371</obo:hasDbXref>
    <obo:source_pmid>10793162</obo:source_pmid>
    <owl:disjointWith rdf:resource="http://poi-kb.org/ards/ARDS_POI_03223"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ARDS_POI_02539">
    <ns1:hasDbXref>Thesaurus.owl#C120932</ns1:hasDbXref>
    <obo:IAO_0000115>The recorded time interval between the initiation of exhalation and the time at which no further lung volume reduction occurs.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_01679">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Scheduled neuromuscular blockade</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_intervention"/>
    <rdfs:subClassOf rdf:resource="http://poi-kb.org/ards/ventilatory-management-strategy"/>
    <obo:hasDbXref>MESH:D009464</obo:hasDbXref>
    <obo:hasDbXref>UMLS:C0027947</obo:hasDbXref>
    <obo:source_pmid>27755068</obo:source_pmid>
    <skos:altLabel xml:lang="en">cisatracurium</skos:altLabel>
    <obo:IAO_0000115 xml:lang="en">Non-depolarising neuromuscular blocking agent (benzylisoquinoline). ROSE trial (PMID 31112383): null in lighter sedation era (90-day mortality 42.5% vs 42.8%, P=0.93). Contrasts with ACURASYS (2010): NMB appeared beneficial in deep sedation era by preventing P-SILI, not via direct NMB effect. Establishes sedation depth as key confounder.</obo:IAO_0000115>
  </rdf:Description>
  <rdf:Description rdf:about="http://poi-kb.org/ards/ARDS_POI_03226">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">Mechanical power</rdfs:label>
    <obo:inSubset rdf:resource="http://poi-kb.org/ards/POI_outcome"/>
    <obo:IAO_0000115 xml:lang="en">Energy delivered to respiratory system per minute (J/min). &gt;17 J/min associated with increased ARDS mortality (PMID 28985207).</obo:IAO_0000115>
    <obo:hasExactSynonym xml:lang="en">MP</obo:hasExactSynonym>
    <obo:hasExactSynonym xml:lang="en">Mechanical power ventilation</obo:hasExactSynonym>
    <obo:source_pmid>28985207</obo:source_pmid>
    <poi:measuredBy rdf:resource="http://poi-kb.org/ards/ARDS_POI_03216"/>
    <poi:measuredBy rdf:resource="http://poi-kb.org/ards/ARDS_POI_03217"/>
  </rdf:Description>
